{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [

    { "id": 1, "type": "row", "title": "📊 Общие метрики", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false },

    {
      "id": 2, "type": "stat", "title": "Requests / sec",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(rate(http_requests_total{service=\"orchestrator\"}[1m]))", "legendFormat": "req/s" }],
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":50},{"color":"red","value":100}] }, "unit": "reqps", "decimals": 2 } }
    },

    {
      "id": 3, "type": "stat", "title": "Активных агентов",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(agents_active)", "legendFormat": "agents" }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"blue","value":null},{"color":"green","value":10},{"color":"yellow","value":100}] }, "unit": "short" } }
    },

    {
      "id": 4, "type": "gauge", "title": "Success Rate агентов",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "100 * sum(rate(tasks_completed_total[5m])) / (sum(rate(tasks_completed_total[5m])) + sum(rate(tasks_failed_total[5m])))",
        "legendFormat": "%"
      }],
      "options": { "minValue": 0, "maxValue": 100, "showThresholdLabels": true },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{"color":"red","value":null},{"color":"yellow","value":80},{"color":"green","value":95}] } } }
    },

    {
      "id": 5, "type": "stat", "title": "Очередь Redis (pending)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "swarm_queue_length", "legendFormat": "pending" }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":500},{"color":"red","value":2000}] }, "unit": "short" } }
    },

    {
      "id": 6, "type": "stat", "title": "AML Pending",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "payments_aml_pending", "legendFormat": "aml_pending" }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":10},{"color":"red","value":50}] }, "unit": "short" } }
    },

    {
      "id": 7, "type": "stat", "title": "Активных платежей",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "payments_active", "legendFormat": "active" }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    { "id": 10, "type": "row", "title": "⏱ Latency", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "collapsed": false },

    {
      "id": 11, "type": "timeseries", "title": "HTTP Latency P50 / P95 / P99 — Orchestrator",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service=\"orchestrator\"}[2m])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"orchestrator\"}[2m])) by (le))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"orchestrator\"}[2m])) by (le))", "legendFormat": "P99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": {"id":"byName","options":"P50"}, "properties": [{"id":"color","value":{"mode":"fixed","fixedColor":"green"}}] },
          { "matcher": {"id":"byName","options":"P95"}, "properties": [{"id":"color","value":{"mode":"fixed","fixedColor":"yellow"}}] },
          { "matcher": {"id":"byName","options":"P99"}, "properties": [{"id":"color","value":{"mode":"fixed","fixedColor":"red"}}] }
        ]
      }
    },

    {
      "id": 12, "type": "timeseries", "title": "Task Duration P50 / P95 / P99 — Agents",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(task_duration_seconds_bucket[2m])) by (le, network))", "legendFormat": "P50 {{network}}" },
        { "expr": "histogram_quantile(0.95, sum(rate(task_duration_seconds_bucket[2m])) by (le, network))", "legendFormat": "P95 {{network}}" },
        { "expr": "histogram_quantile(0.99, sum(rate(task_duration_seconds_bucket[2m])) by (le, network))", "legendFormat": "P99 {{network}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    { "id": 20, "type": "row", "title": "🐝 Swarm Agents", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "collapsed": false },

    {
      "id": 21, "type": "timeseries", "title": "Tasks Completed / Failed per second",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(tasks_completed_total[1m]))", "legendFormat": "completed/s" },
        { "expr": "sum(rate(tasks_failed_total[1m]))",    "legendFormat": "failed/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops",
        "custom": { "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": [
          { "matcher": {"id":"byName","options":"completed/s"}, "properties": [{"id":"color","value":{"mode":"fixed","fixedColor":"#14F195"}}] },
          { "matcher": {"id":"byName","options":"failed/s"},    "properties": [{"id":"color","value":{"mode":"fixed","fixedColor":"#FF060A"}}] }
        ]
      }
    },

    {
      "id": 22, "type": "timeseries", "title": "Активных агентов по сетям",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "agents_active", "legendFormat": "{{network}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    { "id": 30, "type": "row", "title": "🛡 Risk Engine / AML", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }, "collapsed": false },

    {
      "id": 31, "type": "timeseries", "title": "AML Checks по рекомендациям",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(risk_checks_total{recommendation=\"APPROVE\"}[1m]))",       "legendFormat": "APPROVE" },
        { "expr": "sum(rate(risk_checks_total{recommendation=\"MANUAL_REVIEW\"}[1m]))", "legendFormat": "MANUAL_REVIEW" },
        { "expr": "sum(rate(risk_checks_total{recommendation=\"REJECT\"}[1m]))",        "legendFormat": "REJECT" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" },
        "overrides": [
          { "matcher":{"id":"byName","options":"APPROVE"},       "properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"#14F195"}}] },
          { "matcher":{"id":"byName","options":"MANUAL_REVIEW"}, "properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"#F3BA2F"}}] },
          { "matcher":{"id":"byName","options":"REJECT"},        "properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"#FF060A"}}] }
        ]
      }
    },

    {
      "id": 32, "type": "timeseries", "title": "Payment Requests / sec (по статусам)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (status)(rate(payment_requests_total[1m]))", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["most", "swarm", "payments", "production"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MOST — Swarm Payment Network",
  "uid": "most-swarm-001",
  "version": 1
}
