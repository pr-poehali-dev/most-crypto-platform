    {"name": "No token → 401", "method": "POST", "path": "/", "body": {}, "expectedStatus": 401, "expectedBody": {"error": "Требуется авторизация"}, "bodyMatcher": "partial"},
    {"name": "Missing kyc_id → 400", "method": "POST", "path": "/", "headers": {"Authorization": "Bearer bad.tok.en"}, "body": {"action": "approve"}, "expectedStatus": 401, "bodyMatcher": "partial", "expectedBody": {"error": "Требуется авторизация"}},
    {"name": "Bad action → would be 400 (auth first)", "method": "POST", "path": "/", "headers": {"Authorization": "Bearer x.y.z"}, "body": {"kyc_id": "test", "action": "dance"}, "expectedStatus": 401, "bodyMatcher": "partial", "expectedBody": {"error": "Требуется авторизация"}}
  ]
