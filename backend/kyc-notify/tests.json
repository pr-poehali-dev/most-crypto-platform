{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "No token → 401",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 401,
      "expectedBody": {"error": "Требуется авторизация"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Bad token → 401",
      "method": "POST",
      "path": "/",
      "headers": {"Authorization": "Bearer bad.tok.en"},
      "body": {"kyc_id": "test", "action": "approve"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Требуется авторизация"},
      "bodyMatcher": "partial"
    }
  ]
}
