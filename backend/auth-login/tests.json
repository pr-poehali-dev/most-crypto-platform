{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Empty body → 400",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": { "error": "Email и пароль обязательны" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Wrong credentials → 401",
      "method": "POST",
      "path": "/",
      "body": { "email": "nobody@most.network", "password": "WrongPass123" },
      "expectedStatus": 401,
      "expectedBody": { "error": "Неверный email или пароль" },
      "bodyMatcher": "partial"
    }
  ]
}
